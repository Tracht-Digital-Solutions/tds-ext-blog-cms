---
// Blog-CMS settings section, rendered by the base Einstellungen host via
// virtual:panel-settings. Hosts the BlogSettings island, which reads/writes the
// core runtime settings store (`/admin/settings/blog-cms`): DeepL key,
// auto-translate flag, and the rebuild token — DB-first, env fallback in the
// backend. Secrets are stored AES-256-GCM-encrypted by the core.
import BlogSettings from "./BlogSettings.tsx";
---

<div class="settings-section settings-section--blog-cms">
  <h3>Blog-CMS</h3>
  <BlogSettings client:load />
</div>
